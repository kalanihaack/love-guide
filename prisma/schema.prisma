generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  name              String
  email             String          @unique
  password          String
  favoriteMovies    FavoriteMovie[]
  favoriteSongs     FavoriteSong[]
  sent_requests     Friendship[] @relation("SentRequests")
  received_requests Friendship[] @relation("ReceivedRequests")

  @@map("users")
}

model FavoriteMovie {
  id           String   @id @default(uuid())
  movie_api_id String
  title        String
  cover_url    String?
  overview     String?  
  rating       Int      @default(0) // <-- ADICIONE ESTA LINHA (0 significa sem nota)
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])
  created_at   DateTime @default(now())

  @@map("favorite_movies")
}

model FavoriteSong {
  id           String   @id @default(uuid())
  song_api_id  String   // ID da música na API da Apple/Spotify
  title        String
  artist       String
  cover_url    String?
  created_at   DateTime @default(now())
  
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])

  @@map("favorite_songs")
}

model Friendship {
  id          String   @id @default(uuid())
  sender_id   String
  receiver_id String
  status      String   @default("PENDING") // Pode ser PENDING, ACCEPTED ou REJECTED
  created_at  DateTime @default(now())

  sender      User     @relation("SentRequests", fields: [sender_id], references: [id])
  receiver    User     @relation("ReceivedRequests", fields: [receiver_id], references: [id])

  // Garante que o usuário A não consiga mandar 50 convites pro usuário B
  @@unique([sender_id, receiver_id])
  @@map("friendships")
}
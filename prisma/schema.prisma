generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password_hash String
  created_at    DateTime        @default(now())
  
  // Relacionamentos: um usuário pode ter vários filmes e músicas
  movies        FavoriteMovie[]
  songs         FavoriteSong[]

  @@map("users") // Nome da tabela no banco
}

model FavoriteMovie {
  id           String   @id @default(uuid())
  movie_api_id String   // ID do filme na API do TMDB
  title        String
  director     String?  // O "?" significa que é opcional
  cover_url    String?
  created_at   DateTime @default(now())
  
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])

  @@map("favorite_movies")
}

model FavoriteSong {
  id           String   @id @default(uuid())
  song_api_id  String   // ID da música na API da Apple/Spotify
  title        String
  artist       String
  cover_url    String?
  created_at   DateTime @default(now())
  
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])

  @@map("favorite_songs")
}